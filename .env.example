# ─── Core ────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Database (PostgreSQL is the only supported dialect — ADR-002) ───────
# DATABASE_URL is what `pnpm dev` (no compose) connects to — localhost.
# Inside `docker compose up`, api/worker/migrate get DATABASE_URL rewritten
# to point at the `postgres` service instead (see docker-compose.yml); the
# POSTGRES_* vars below are what actually provisions that container.
DATABASE_URL=postgresql://careerpilot:careerpilot@localhost:5432/careerpilot
POSTGRES_USER=careerpilot
POSTGRES_PASSWORD=careerpilot
POSTGRES_DB=careerpilot

# ─── Redis (BullMQ queues + sessions + pub/sub) ──────────────────────────
# Same story as DATABASE_URL — this is the non-compose value.
REDIS_URL=redis://localhost:6379

# ─── API ─────────────────────────────────────────────────────────────────
API_PORT=8080
# Generate with: openssl rand -hex 32   (NEVER commit a real value)
SESSION_SECRET=replace-me-with-32-byte-hex

# ─── LLM (ADR-006: local-default, BYO-key-recommended) ───────────────────
# Default is a local Ollama endpoint — the stack boots with NO cloud key.
# Same localhost/compose split as DATABASE_URL above: this value is for
# `pnpm dev` (no compose). Inside `docker compose up`, the worker uses
# DOCKER_LLM_BASE_URL instead (defaults to host.docker.internal, which reaches
# an Ollama instance running on the host from inside the container). Point
# DOCKER_LLM_BASE_URL at a cloud provider here if you're running compose with
# a BYO key instead of local Ollama.
LLM_BASE_URL=http://localhost:11434/v1
DOCKER_LLM_BASE_URL=
LLM_API_KEY=
LLM_EMBEDDING_MODEL=nomic-embed-text
LLM_EMBEDDING_DIMENSIONS=768
# Hard stop. The budget guard blocks dispatch before any network call.
LLM_MONTHLY_BUDGET_USD=10.00

# ─── Outbox relay (ADR-007) ──────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=5
